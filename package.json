{
  "name": "@yolfi/agent",
  "version": "0.1.0",
  "description": "Thin SDK, CLI, and MCP adapter that lets AI coding agents integrate Yolfi payments.",
  "type": "module",
  "homepage": "https://yolfi.com/ai-agent-kit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yolfinance/yolfi-agent.git"
  },
  "bugs": {
    "url": "https://github.com/yolfinance/yolfi-agent/issues"
  },
  "bin": {
    "yolfi": "src/cli.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./mcp": "./src/mcp.js"
  },
  "files": [
    "src",
    "examples",
    "README.md",
    "SKILL.md"
  ],
  "scripts": {
    "test": "node --test",
    "lint": "node --check src/*.js"
  },
  "keywords": [
    "mcp",
    "ai-agents",
    "crypto-payments",
    "payment-api",
    "checkout",
    "webhooks",
    "stablecoins"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
