{
  "name": "@yolfi/agent",
  "version": "0.2.0",
  "description": "AI agent payment integration SDK, CLI, and MCP server for adding Yolfi crypto checkout, payment links, webhooks, and payment status checks.",
  "type": "module",
  "mcpName": "io.github.yolfinance/yolfi-agent",
  "homepage": "https://yolfi.com/ai-agent-kit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yolfinance/yolfi-agent.git"
  },
  "bugs": {
    "url": "https://github.com/yolfinance/yolfi-agent/issues"
  },
  "bin": {
    "yolfi": "src/cli.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./mcp": "./src/mcp.js"
  },
  "files": [
    ".dockerignore",
    ".mcp.json",
    ".codex-plugin",
    ".claude-plugin",
    "Dockerfile",
    "src",
    "skills",
    "examples",
    "assets",
    "docs",
    "glama.json",
    "server.json",
    "LICENSE",
    "README.md",
    "SKILL.md"
  ],
  "scripts": {
    "check": "npm run lint && npm test",
    "test": "node --test",
    "lint": "node --check src/*.js"
  },
  "keywords": [
    "yolfi",
    "yolfi-agent-kit",
    "ai-agent-payment-integration",
    "ai-agent-payments",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-agents",
    "ai-agent-tools",
    "agentic-payments",
    "crypto-payments",
    "stablecoin-payments",
    "payment-api",
    "payment-links",
    "checkout",
    "checkout-api",
    "webhooks",
    "webhook-verification",
    "stablecoins",
    "subscriptions",
    "donations",
    "codex",
    "claude-code",
    "chatgpt",
    "cursor",
    "openclaw"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
